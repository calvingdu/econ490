. // 4. MAIN RESULT: COMBINED EMIGRATION
. display as text "------ MAIN RESULT: Total Emigration Rate ------"
------ MAIN RESULT: Total Emigration Rate ------

. 
. quietly xtpcse dlngdp L1.lngdp lnsave lnschool lnn lnemig_combined i.ccode i
> .year, het

. estimates store model_combined

. estimates title: "Combined"

. etable, estimates(model_combined) ///
>     mstat(N) mstat(r2)                         ///
>     showstars showstarsnote varlabel            ///
>         keep(dlngdp L1.lngdp lnsave lnschool lnn lnemig_combined lnemig_male
>  lnemig_female) ///
>         title("Main Result") ///
>     export("2.output/EmigrationTable_MainResult.docx", replace)

