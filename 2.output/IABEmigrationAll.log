. // 5. HETEROGENEITY: INCOME GROUP
. // 1=High income, 2=Low income, 3=Lower middle income, 4=Upper middle income
. display as text "------ INCOME GROUP ------"
------ INCOME GROUP ------

. levelsof income_group, local(income_groups)
`"High income"' `"Low income"' `"Lower middle income"' `"Upper middle income"'

. display `"`income_groups'"'
`"High income"' `"Low income"' `"Lower middle income"' `"Upper middle income"'

. local i = 1

. foreach r of local income_groups {
  2.     preserve
  3.     keep if income_group == "`r'"
  4.     quietly xtpcse dlngdp L1.lngdp lnsave lnschool lnn lnemig_combined i.
> ccode i.year, het
  5.     estimates store group_`i'
  6.         estimates title: "`r'"
  7.     local i = `i' + 1
  8.     restore
  9. }
