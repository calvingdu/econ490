. // 2.5 WINSORIZE ALL REGRESSION VARIABLES (p1/p99)
. local winsor_vars "dlngdp lngdp lnsave lnschool lnn lnemig_combined lnemig_male lnemig_female"

. 
. *test if we should winsorize
. foreach v of local winsor_vars {
  2.         quietly summarize `v', detail
  3.         local ratio_lb = round(r(p1)/r(min))
  4.         local ratio_ub = round(r(max)/r(p99))
  5.         display "First percentile `v' is `r(p1)'"
  6.         display "Min `v' is `r(min)'"
  7.         display "99th percentile `v' is `r(p99)' "
  8.         display "Max `v' is `r(max)'"
  9.         display "1st percentile `v' is `ratio_lb' times the minimum"
 10.         display "Max `v' is `ratio_ub' times as much as the 99th percentile!"
 11. }
